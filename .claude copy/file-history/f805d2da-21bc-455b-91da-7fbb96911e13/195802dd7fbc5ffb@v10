'use client'

import { useEffect, useState } from 'react'
import { useRouter } from 'next/navigation'
import Image from 'next/image'
import { supabase } from '@/lib/supabase'

export default function LandingPage() {
  const router = useRouter()
  const [showSignIn, setShowSignIn] = useState(false)
  const [loading, setLoading] = useState(false)
  const [mounted, setMounted] = useState(false)

  useEffect(() => {
    // Trigger entrance animation
    const t = setTimeout(() => setMounted(true), 60)
    // Redirect if already signed in
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) router.replace('/home')
    })
    return () => clearTimeout(t)
  }, [router])

  async function signInWithGoogle() {
    setLoading(true)
    await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: `${window.location.origin}/auth/callback` },
    })
  }

  return (
    <div className="min-h-screen bg-fog-200 flex flex-col items-center justify-center px-6 relative overflow-hidden">

      {/* Background glows */}
      <div className="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div
          className="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] opacity-60"
          style={{ background: 'radial-gradient(ellipse at center top, #d5e0ed 0%, transparent 70%)' }}
        />
        <div
          className="absolute bottom-0 right-0 w-[600px] h-[500px] opacity-25"
          style={{ background: 'radial-gradient(ellipse at bottom right, #fae3c0 0%, transparent 65%)' }}
        />
        <div
          className="absolute bottom-0 left-0 w-[400px] h-[400px] opacity-20"
          style={{ background: 'radial-gradient(ellipse at bottom left, #d5e0ed 0%, transparent 70%)' }}
        />
      </div>

      {/* ── Hero ──────────────────────────────────────────────────────────── */}
      <div
        className={`
          flex flex-col items-center text-center select-none
          transition-all duration-700 ease-out
          ${mounted ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4'}
          ${showSignIn ? 'opacity-0 -translate-y-3 scale-[0.97] pointer-events-none' : ''}
        `}
        style={{ transitionProperty: 'opacity, transform' }}
      >
        {/* Logo */}
        <div className="w-24 h-24 rounded-[26px] shadow-[0_12px_48px_rgba(14,30,53,0.16)] overflow-hidden mb-8 ring-1 ring-navy-200/50">
          <Image
            src="/apple-touch-icon.png"
            alt="MindWell"
            width={96}
            height={96}
            className="w-full h-full object-cover"
            priority
          />
        </div>

        {/* Wordmark */}
        <h1
          className="text-[4rem] font-bold tracking-tight leading-none mb-4"
          style={{ color: '#191970' }}
        >
          MindWell
        </h1>

        {/* Tagline */}
        <p
          className="text-[1.1rem] text-fog-600 leading-snug mb-4"
          style={{ fontFamily: 'var(--font-lora), Georgia, serif', fontStyle: 'italic' }}
        >
          Your reading life, organized.
        </p>

        {/* Description */}
        <p className="text-sm text-fog-500 leading-relaxed max-w-[280px] mb-10">
          Track books, articles, and podcasts. Capture quotes, build outlines, and brainstorm ideas.
          <br />
          <span className="font-semibold italic">All in one quiet place.</span>
        </p>

        {/* Get Started button */}
        <button
          onClick={() => setShowSignIn(true)}
          className="group flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-semibold tracking-wide transition-all duration-200"
          style={{
            background: '#191970',
            color: '#fff',
            boxShadow: '0 2px 8px rgba(25,25,112,0.22), 0 8px 28px rgba(25,25,112,0.14)',
          }}
          onMouseEnter={e => {
            const btn = e.currentTarget as HTMLButtonElement
            btn.style.boxShadow = '0 4px 16px rgba(25,25,112,0.30), 0 14px_36px rgba(25,25,112,0.18)'
            btn.style.transform = 'translateY(-1px)'
          }}
          onMouseLeave={e => {
            const btn = e.currentTarget as HTMLButtonElement
            btn.style.boxShadow = '0 2px 8px rgba(25,25,112,0.22), 0 8px 28px rgba(25,25,112,0.14)'
            btn.style.transform = 'translateY(0)'
          }}
        >
          Get Started
          <span className="transition-transform duration-200 group-hover:translate-x-0.5">→</span>
        </button>

        {/* Footer links */}
        <p className="flex items-center gap-2 text-[11px] text-fog-400 mt-10">
          <a href="/privacy" className="hover:text-navy-500 transition-colors underline underline-offset-2">
            Privacy Policy
          </a>
          <span aria-hidden="true">·</span>
          <a href="/tos" className="hover:text-navy-500 transition-colors underline underline-offset-2">
            Terms of Service
          </a>
        </p>
      </div>

      {/* ── Sign-in overlay ───────────────────────────────────────────────── */}
