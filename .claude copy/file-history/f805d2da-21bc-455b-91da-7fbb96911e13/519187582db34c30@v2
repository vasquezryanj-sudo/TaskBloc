export interface RecentlyViewedItem {
  id: string
  title: string
  type: 'book' | 'article' | 'podcast'
}

const MAX = 5
const storageKey = (userId: string) => `mindwell:recently-viewed:${userId}`

export function getRecentlyViewed(userId: string): RecentlyViewedItem[] {
  try {
    const raw = localStorage.getItem(storageKey(userId))
    return raw ? (JSON.parse(raw) as RecentlyViewedItem[]) : []
  } catch {
    return []
  }
}

export function trackRecentlyViewed(userId: string, item: RecentlyViewedItem): void {
  try {
    const current = getRecentlyViewed(userId)
    // Move to front, deduplicate, cap at MAX
    const updated = [item, ...current.filter(i => i.id !== item.id)].slice(0, MAX)
    localStorage.setItem(storageKey(userId), JSON.stringify(updated))
  } catch {
    // localStorage unavailable — fail silently
  }
}
