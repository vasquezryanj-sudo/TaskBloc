import { NextRequest } from 'next/server'
import { createSupabaseServerClient } from '@/lib/supabase-server'

export async function POST(req: NextRequest) {
  const supabase = await createSupabaseServerClient()
  const { book_id, name } = await req.json()
  if (!book_id || !name) {
    return Response.json({ error: 'book_id and name are required' }, { status: 400 })
  }

  // Get max sort_order for this book's headings
  const { data: existing } = await supabase
    .from('quote_headings')
    .select('sort_order')
    .eq('book_id', book_id)

  const maxOrder = Math.max(0, ...((existing ?? []).map((h: { sort_order: number }) => h.sort_order)))

  const { data, error } = await supabase
    .from('quote_headings')
    .insert({ book_id, name, sort_order: maxOrder + 1 })
    .select()
    .single()

  if (error) return Response.json({ error: error.message }, { status: 500 })
  return Response.json(data, { status: 201 })
}
