'use client'

import { Suspense, useEffect } from 'react'
import { useParams, useSearchParams, useRouter } from 'next/navigation'

function Redirector() {
  const { id } = useParams<{ id: string }>()
  const searchParams = useSearchParams()
  const router = useRouter()

  useEffect(() => {
    const tab = searchParams.get('tab') ?? 'outline'
    // Map legacy 'scratch' tab to 'brainstorm'
    const mappedTab = tab === 'scratch' ? 'brainstorm' : tab
    router.replace(`/?book=${id}&tab=${mappedTab}`)
  }, [id, searchParams, router])

  return (
    <div className="min-h-screen bg-fog-200 flex items-center justify-center text-fog-500 text-sm">
      Loading…
    </div>
  )
}

export default function BookRedirectPage() {
  return (
    <Suspense fallback={
      <div className="min-h-screen bg-fog-200 flex items-center justify-center text-fog-500 text-sm">
        Loading…
      </div>
    }>
      <Redirector />
    </Suspense>
  )
}
