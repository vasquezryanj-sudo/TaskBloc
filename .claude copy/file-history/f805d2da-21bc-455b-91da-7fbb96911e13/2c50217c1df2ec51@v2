import { NextRequest, NextResponse } from 'next/server'
import { createSupabaseServerClient } from '@/lib/supabase-server'
import type { SearchResult, Book, Quote } from '@/types'

export async function GET(req: NextRequest) {
  const supabase = await createSupabaseServerClient()
  const q = req.nextUrl.searchParams.get('q')?.trim()
  if (!q || q.length < 2) {
    return NextResponse.json({ results: [] })
  }

  const [quotesRes, tagQuotesRes, notesRes] = await Promise.all([
    // Search in quote text
    supabase
      .from('quotes')
      .select('*, book:books(id, title)')
      .ilike('quote_text', `%${q}%`)
      .limit(25),
    // Search by exact tag match
    supabase
      .from('quotes')
      .select('*, book:books(id, title)')
      .contains('tags', [q])
      .limit(15),
    // Search in notes/insights
    supabase
      .from('book_notes')
      .select('*, book:books(id, title)')
      .ilike('content', `%${q}%`)
      .limit(25),
  ])

  const seenQuoteIds = new Set<string>()
  const results: SearchResult[] = []

  for (const quote of [...(quotesRes.data ?? []), ...(tagQuotesRes.data ?? [])]) {
    if (seenQuoteIds.has(quote.id)) continue
    seenQuoteIds.add(quote.id)
    const book = quote.book as Book
    results.push({
      type: 'quote',
      id: quote.id,
      bookId: book.id,
      bookTitle: book.title,
      content: quote.quote_text,
      tags: (quote as Quote).tags ?? [],
      pageNumber: quote.page_number,
    })
  }

  for (const note of notesRes.data ?? []) {
    const book = note.book as Book
    results.push({
      type: 'note' as const,
      id: note.id,
      bookId: book.id,
      bookTitle: book.title,
      content: note.content,
      tab: note.tab,
    })
  }

  return NextResponse.json({ results })
}
