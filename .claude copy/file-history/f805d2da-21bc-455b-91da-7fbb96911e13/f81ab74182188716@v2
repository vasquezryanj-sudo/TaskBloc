import { createSupabaseServerClient } from '@/lib/supabase-server'

export async function DELETE() {
  const supabase = await createSupabaseServerClient()
  // Delete in dependency order (children before parents)
  await supabase.from('sessions').delete().neq('id', '00000000-0000-0000-0000-000000000000')
  await supabase.from('quotes').delete().neq('id', '00000000-0000-0000-0000-000000000000')
  await supabase.from('quote_headings').delete().neq('id', '00000000-0000-0000-0000-000000000000')
  await supabase.from('book_notes').delete().neq('id', '00000000-0000-0000-0000-000000000000')
  await supabase.from('priority_items').delete().neq('id', '00000000-0000-0000-0000-000000000000')
  await supabase.from('books').delete().neq('id', '00000000-0000-0000-0000-000000000000')

  return Response.json({ success: true })
}
