'use client'

import { useEffect, useRef, useState } from 'react'
import { getRecentlyViewed, type RecentlyViewedItem } from '@/lib/recentlyViewed'

const TYPE_ICON: Record<RecentlyViewedItem['type'], string> = {
  book: '📚',
  article: '📰',
  podcast: '🎙️',
}

interface Props {
  userId: string
  onOpen: (bookId: string) => void
  // Increment this whenever a new item is tracked so the list stays fresh
  refreshKey: number
}

export default function RecentlyViewedDropdown({ userId, onOpen, refreshKey }: Props) {
  const [open, setOpen] = useState(false)
  const [items, setItems] = useState<RecentlyViewedItem[]>([])
  const containerRef = useRef<HTMLDivElement>(null)

  // Re-read from localStorage whenever the dropdown opens or a new item is tracked
  useEffect(() => {
    if (open) {
      setItems(getRecentlyViewed(userId))
    }
  }, [open, userId, refreshKey])

  // Close on click outside
  useEffect(() => {
    if (!open) return
    function onPointerDown(e: PointerEvent) {
      if (containerRef.current && !containerRef.current.contains(e.target as Node)) {
        setOpen(false)
      }
    }
    document.addEventListener('pointerdown', onPointerDown)
    return () => document.removeEventListener('pointerdown', onPointerDown)
  }, [open])

  // Close on Escape
  useEffect(() => {
    if (!open) return
    function onKey(e: KeyboardEvent) {
      if (e.key === 'Escape') setOpen(false)
    }
    document.addEventListener('keydown', onKey)
    return () => document.removeEventListener('keydown', onKey)
  }, [open])

  return (
    <div ref={containerRef} className="relative">
      <button
        onClick={() => setOpen(v => !v)}
        className="text-fog-600 hover:text-navy-700 px-3 py-1.5 rounded-full bg-fog-100 hover:bg-fog-200 text-sm flex items-center gap-2 transition-all"
        title="Recently viewed"
        aria-expanded={open}
      >
        {/* Clock icon */}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" className="w-3.5 h-3.5 shrink-0">
          <path fillRule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clipRule="evenodd" />
        </svg>
        <span className="hidden sm:inline">Recent</span>
      </button>

      {open && (
        <div className="absolute right-0 top-full mt-2 w-64 bg-white rounded-xl border border-fog-300 shadow-xl z-50 overflow-hidden">
          <p className="text-[10px] font-bold uppercase tracking-widest text-fog-500 px-4 pt-3 pb-2">
            Recently Viewed
          </p>

          {items.length === 0 ? (
            <p className="text-xs text-fog-400 px-4 pb-4">Nothing yet — open an item to start tracking.</p>
          ) : (
            <ul className="pb-2">
              {items.map(item => (
                <li key={item.id}>
                  <button
                    onClick={() => { setOpen(false); onOpen(item.id) }}
                    className="w-full flex items-center gap-3 px-4 py-2.5 text-left hover:bg-fog-50 transition-colors group"
                  >
                    <span className="text-base shrink-0 leading-none">{TYPE_ICON[item.type]}</span>
                    <span className="text-sm text-navy-800 group-hover:text-navy-900 truncate leading-snug">
                      {item.title}
                    </span>
                  </button>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}
    </div>
  )
}
