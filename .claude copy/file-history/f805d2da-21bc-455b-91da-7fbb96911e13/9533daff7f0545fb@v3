'use client'

import { useEffect, useState, Suspense } from 'react'
import { useRouter, useSearchParams } from 'next/navigation'
import Image from 'next/image'
import { supabase } from '@/lib/supabase'

function LoginContent() {
  const router = useRouter()
  const searchParams = useSearchParams()
  const [loading, setLoading] = useState(false)
  const error = searchParams.get('error')

  useEffect(() => {
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) router.replace('/')
    })
  }, [router])

  async function signInWithGoogle() {
    setLoading(true)
    await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: `${window.location.origin}/auth/callback`,
      },
    })
  }

  return (
    <div className="min-h-screen bg-fog-200 flex flex-col items-center justify-center px-6 relative overflow-hidden">

      {/* Subtle radial glow behind the card */}
      <div
        className="absolute inset-0 pointer-events-none"
        aria-hidden="true"
      >
        <div
          className="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[520px] opacity-50"
          style={{
            background: 'radial-gradient(ellipse at center top, #d5e0ed 0%, transparent 70%)',
          }}
        />
        <div
          className="absolute bottom-0 right-0 w-[500px] h-[400px] opacity-30"
          style={{
            background: 'radial-gradient(ellipse at bottom right, #fae3c0 0%, transparent 65%)',
          }}
        />
      </div>

      {/* Main card */}
      <div className="w-full max-w-[360px] relative">

        {/* Logo + wordmark — floats above the card */}
        <div className="flex flex-col items-center mb-8">
          <div className="w-20 h-20 rounded-[22px] shadow-lg overflow-hidden mb-5 ring-1 ring-navy-200/60">
            <Image
              src="/apple-touch-icon.png"
              alt="MindWell"
              width={80}
              height={80}
              className="w-full h-full object-cover"
              priority
            />
          </div>

          <h1
            className="text-[2.6rem] font-bold tracking-tight leading-none mb-3"
            style={{ color: '#191970' }}
          >
            MindWell
          </h1>

          <p
            className="text-base text-fog-600 text-center leading-snug"
            style={{ fontFamily: 'var(--font-lora), Georgia, serif', fontStyle: 'italic' }}
          >
            Your reading life, organized.
          </p>
        </div>

        {/* Sign-in card */}
        <div className="bg-white rounded-3xl border border-fog-300 shadow-xl overflow-hidden">

          {/* Amber accent bar at the top */}
          <div className="h-[3px] bg-gradient-to-r from-ember-300 via-ember-400 to-ember-300" />

          <div className="px-8 py-8 flex flex-col gap-5">

            <p className="text-[10px] font-bold uppercase tracking-[0.18em] text-fog-500 text-center">
              Sign in to continue
            </p>

            {/* Google OAuth button */}
            <button
              onClick={signInWithGoogle}
              disabled={loading}
              className="w-full flex items-center gap-3 px-5 py-[13px] rounded-xl text-sm font-semibold transition-all disabled:opacity-60"
              style={{
                background: loading ? '#142d55' : '#1a3a6b',
                color: '#ffffff',
                boxShadow: '0 1px 3px rgba(26,58,107,0.25), 0 4px 12px rgba(26,58,107,0.15)',
              }}
              onMouseEnter={e => {
                if (!loading) (e.currentTarget as HTMLButtonElement).style.background = '#142d55'
              }}
              onMouseLeave={e => {
                if (!loading) (e.currentTarget as HTMLButtonElement).style.background = '#1a3a6b'
              }}
            >
              {/* Google G mark in white pill */}
              <span className="w-7 h-7 bg-white rounded-lg flex items-center justify-center shrink-0">
                <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
                  <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615Z" fill="#4285F4"/>
                  <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z" fill="#34A853"/>
                  <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332Z" fill="#FBBC05"/>
                  <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58Z" fill="#EA4335"/>
                </svg>
              </span>
              <span className="flex-1 text-center">
                {loading ? 'Redirecting…' : 'Continue with Google'}
              </span>
            </button>

            {error && (
              <p className="text-xs text-red-500 text-center -mt-1">
                {error === 'auth_failed'
                  ? 'Sign-in failed. Please try again.'
                  : 'Something went wrong. Please try again.'}
              </p>
            )}

          </div>
        </div>

        {/* Footer note */}
        <p className="text-center text-[11px] text-fog-400 mt-6 leading-relaxed">
          Your notes and highlights stay private.
          <br />No public sharing, no ads.
        </p>

      </div>
    </div>
  )
}

export default function LoginPage() {
  return (
    <Suspense>
      <LoginContent />
    </Suspense>
  )
}
