'use client'

import { useState } from 'react'
import Modal from './Modal'

interface Props {
  onClose: () => void
  onSuccess: () => void
}

export default function AddBookModal({ onClose, onSuccess }: Props) {
  const [form, setForm] = useState({ title: '', total_pages: '', current_page: '0' })
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState('')

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault()
    setError('')
    setLoading(true)

    const res = await fetch('/api/books', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        title: form.title.trim(),
        total_pages: Number(form.total_pages),
        current_page: Number(form.current_page),
        sessions_per_week: 4,
      }),
    })

    if (!res.ok) {
      const data = await res.json()
      setError(data.error ?? 'Failed to add book')
      setLoading(false)
      return
    }

    onSuccess()
    onClose()
  }

  return (
    <Modal title="Add Book" onClose={onClose}>
      <form onSubmit={handleSubmit} className="space-y-4">
        <div>
          <label className="block text-sm font-medium text-well-200 mb-1">Title</label>
          <input
            type="text"
            required
            autoFocus
            value={form.title}
            onChange={e => setForm(f => ({ ...f, title: e.target.value }))}
            className="w-full border border-well-800 bg-well-950 rounded-lg px-3 py-2 text-sm text-well-50 placeholder:text-well-500 focus:outline-none focus:ring-2 focus:ring-ripple-600/20 focus:border-ripple-600/40 transition-all"
            placeholder="Book title"
          />
        </div>

        <div className="grid grid-cols-2 gap-3">
          <div>
            <label className="block text-sm font-medium text-well-200 mb-1">Total pages</label>
            <input
              type="number"
              required
              min={1}
              value={form.total_pages}
              onChange={e => setForm(f => ({ ...f, total_pages: e.target.value }))}
              className="w-full border border-well-800 bg-well-950 rounded-lg px-3 py-2 text-sm text-well-50 placeholder:text-well-500 focus:outline-none focus:ring-2 focus:ring-ripple-600/20 focus:border-ripple-600/40 transition-all"
              placeholder="450"
            />
          </div>
          <div>
            <label className="block text-sm font-medium text-well-200 mb-1">Current page</label>
            <input
              type="number"
              min={0}
              value={form.current_page}
              onChange={e => setForm(f => ({ ...f, current_page: e.target.value }))}
              className="w-full border border-well-800 bg-well-950 rounded-lg px-3 py-2 text-sm text-well-50 placeholder:text-well-500 focus:outline-none focus:ring-2 focus:ring-ripple-600/20 focus:border-ripple-600/40 transition-all"
              placeholder="0"
            />
          </div>
        </div>

        {error && <p className="text-sm text-rose-400">{error}</p>}

        <div className="flex gap-3 pt-1">
          <button
            type="button"
            onClick={onClose}
            className="flex-1 border border-well-800 text-well-300 px-4 py-2 rounded-lg text-sm hover:bg-well-800/60 transition-colors"
          >
            Cancel
          </button>
          <button
            type="submit"
            disabled={loading}
            className="flex-1 bg-ripple-600 hover:bg-ripple-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all disabled:opacity-50 shadow-[0_0_12px_rgba(8,116,224,0.2)]"
          >
            {loading ? 'Adding…' : 'Add Book'}
          </button>
        </div>
      </form>
    </Modal>
  )
}
