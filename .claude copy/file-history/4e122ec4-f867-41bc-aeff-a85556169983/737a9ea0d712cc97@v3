@import "tailwindcss";

@theme inline {
  --font-sans: var(--font-geist);
  --font-serif: var(--font-lora);
}

@theme {
  /* Base — Spotify-dark neutral scale */
  --color-well-50:  #ffffff;   /* primary text — pure white */
  --color-well-100: #f5f5f5;
  --color-well-200: #e0e0e0;
  --color-well-300: #b3b3b3;   /* Spotify secondary text */
  --color-well-400: #9e9e9e;
  --color-well-500: #6a6a6a;
  --color-well-600: #535353;   /* Spotify muted */
  --color-well-700: #404040;
  --color-well-800: #282828;   /* elevated card */
  --color-well-900: #181818;   /* card background */
  --color-well-950: #121212;   /* page background */

  /* Ripple — indigo accent */
  --color-ripple-50:  #eef2ff;
  --color-ripple-100: #e0e7ff;
  --color-ripple-200: #c7d2fe;
  --color-ripple-300: #a5b4fc;
  --color-ripple-400: #818cf8;
  --color-ripple-500: #6366f1;
  --color-ripple-600: #4f46e5;   /* primary button */
  --color-ripple-700: #4338ca;
  --color-ripple-800: #3730a3;
  --color-ripple-900: #312e81;
  --color-ripple-950: #1e1b4b;
}

*, *::before, *::after {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-sans), system-ui, sans-serif;
  background-color: #121212;
}

/* Thin, unobtrusive scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background-color: #404040;
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover {
  background-color: #535353;
}
