@import "tailwindcss";

@theme inline {
  --font-sans: var(--font-geist);
  --font-serif: var(--font-lora);
}

@theme {
  /* Well — the deep still well (dark surfaces and luminous text) */
  --color-well-50:  #eef2ff;   /* primary text on dark bg */
  --color-well-100: #d4e2ff;   /* secondary text */
  --color-well-200: #a8c4ff;   /* medium-light text */
  --color-well-300: #6aa0f0;   /* muted text */
  --color-well-400: #3a78d8;   /* interactive muted */
  --color-well-500: #1e58b8;   /* standard interactive */
  --color-well-600: #113e96;   /* deep interactive */
  --color-well-700: #0a2870;   /* very deep */
  --color-well-800: #1a2e4a;   /* borders / elevated surface */
  --color-well-900: #0c1830;   /* card background */
  --color-well-950: #060e20;   /* page background */

  /* Ripple — glowing accent blue (like light on still water) */
  --color-ripple-50:  #eef8ff;
  --color-ripple-100: #daeeff;
  --color-ripple-200: #aed8ff;
  --color-ripple-300: #72beff;
  --color-ripple-400: #3aa8ff;   /* soft hover */
  --color-ripple-500: #1090ff;   /* standard interactive */
  --color-ripple-600: #0874e0;   /* primary button */
  --color-ripple-700: #055ab8;   /* button hover */
  --color-ripple-800: #03408c;
  --color-ripple-900: #022868;
  --color-ripple-950: #011440;
}

body {
  font-family: var(--font-sans), system-ui, sans-serif;
}
