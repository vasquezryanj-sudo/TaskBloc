'use client'

interface ModalProps {
  title: string
  onClose: () => void
  children: React.ReactNode
}

export default function Modal({ title, onClose, children }: ModalProps) {
  return (
    <div
      className="fixed inset-0 bg-well-950/80 backdrop-blur-sm flex items-center justify-center z-50 p-4"
      onClick={e => { if (e.target === e.currentTarget) onClose() }}
    >
      <div className="bg-well-900 rounded-xl shadow-[0_8px_48px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.04)] border border-well-800 w-full max-w-md">
        <div className="flex items-center justify-between px-6 py-4 border-b border-well-800">
          <h2 className="font-semibold text-well-50">{title}</h2>
          <button
            onClick={onClose}
            className="text-well-400 hover:text-well-100 text-xl leading-none transition-colors"
          >
            ×
          </button>
        </div>
        <div className="px-6 py-5">{children}</div>
      </div>
    </div>
  )
}
