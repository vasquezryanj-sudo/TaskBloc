'use client'

import { useState } from 'react'

interface Props {
  onClose: () => void
  onSuccess: () => void
}

export default function AddArticleModal({ onClose, onSuccess }: Props) {
  const [title, setTitle] = useState('')
  const [submitting, setSubmitting] = useState(false)
  const [error, setError] = useState('')

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault()
    if (!title.trim()) return
    setSubmitting(true)
    setError('')

    const res = await fetch('/api/books', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: title.trim(), type: 'article' }),
    })

    if (!res.ok) {
      const data = await res.json()
      setError(data.error ?? 'Something went wrong')
      setSubmitting(false)
      return
    }

    onSuccess()
    onClose()
  }

  return (
    <div
      className="fixed inset-0 bg-well-950/80 backdrop-blur-sm flex items-center justify-center z-50 p-4"
      onClick={e => { if (e.target === e.currentTarget) onClose() }}
    >
      <div className="bg-well-900 rounded-xl shadow-[0_8px_48px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.04)] border border-well-800 w-full max-w-sm">
        <div className="flex items-center justify-between px-6 py-4 border-b border-well-800">
          <h2 className="font-semibold text-well-50">Add Article</h2>
          <button
            onClick={onClose}
            className="text-well-400 hover:text-well-100 text-xl leading-none transition-colors"
          >
            ×
          </button>
        </div>

        <form onSubmit={handleSubmit} className="px-6 py-5 space-y-4">
          <div>
            <label className="block text-sm text-well-200 mb-1.5 font-medium">Title</label>
            <input
              autoFocus
              value={title}
              onChange={e => setTitle(e.target.value)}
              placeholder="Article title…"
              className="w-full border border-well-800 bg-well-950 rounded-lg px-3 py-2 text-sm text-well-50 placeholder:text-well-500 focus:outline-none focus:ring-2 focus:ring-ripple-600/20 focus:border-ripple-600/40 transition-all"
            />
          </div>

          {error && <p className="text-sm text-rose-400">{error}</p>}

          <div className="flex gap-3 pt-1">
            <button
              type="button"
              onClick={onClose}
              className="flex-1 border border-well-800 text-well-300 px-4 py-2 rounded-lg text-sm hover:bg-well-800/60 transition-colors"
            >
              Cancel
            </button>
            <button
              type="submit"
              disabled={submitting || !title.trim()}
              className="flex-1 bg-ripple-600 hover:bg-ripple-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all disabled:opacity-40 shadow-[0_0_12px_rgba(8,116,224,0.2)]"
            >
              {submitting ? 'Adding…' : 'Add Article'}
            </button>
          </div>
        </form>
      </div>
    </div>
  )
}
