'use client'

interface ModalProps {
  title: string
  onClose: () => void
  children: React.ReactNode
}

export default function Modal({ title, onClose, children }: ModalProps) {
  return (
    <div
      className="fixed inset-0 bg-black/70 backdrop-blur-md flex items-center justify-center z-50 p-4"
      onClick={e => { if (e.target === e.currentTarget) onClose() }}
    >
      <div className="bg-well-900 rounded-2xl shadow-[0_24px_80px_rgba(0,0,0,0.9)] w-full max-w-md">
        <div className="flex items-center justify-between px-6 py-5 border-b border-well-800/60">
          <h2 className="font-semibold text-well-50 text-base tracking-tight">{title}</h2>
          <button
            onClick={onClose}
            className="w-7 h-7 flex items-center justify-center rounded-full text-well-500 hover:text-well-200 hover:bg-well-800 text-lg leading-none transition-all"
          >
            ×
          </button>
        </div>
        <div className="px-6 py-5">{children}</div>
      </div>
    </div>
  )
}
