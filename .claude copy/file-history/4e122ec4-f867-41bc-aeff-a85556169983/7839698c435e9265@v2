export type BookStatus = 'active' | 'completed' | 'paused'
export type BookType = 'book' | 'article'
export type NoteTab = 'outline' | 'scratch' | 'insights'

export interface Book {
  id: string
  title: string
  type: BookType
  current_page: number
  total_pages: number
  sessions_per_week: number
  sort_order: number | null
  status: BookStatus
  date_finished: string | null // YYYY-MM-DD
  created_at: string
  updated_at: string
}

export interface Session {
  id: string
  book_id: string
  scheduled_date: string // ISO date string YYYY-MM-DD
  pages_start: number
  pages_end: number
  actual_end_page: number | null
  is_completed: boolean
  order_index: number
  created_at: string
  updated_at: string
  // joined
  book?: Book
}

export interface PriorityItem {
  id: string
  title: string
  description: string | null
  sessions_needed: number
  scheduled_date: string // ISO date string YYYY-MM-DD
  is_completed: boolean
  created_at: string
}

export interface BookNote {
  id: string
  book_id: string
  tab: NoteTab
  content: string
  updated_at: string
}

export interface Quote {
  id: string
  book_id: string
  quote_text: string
  page_number: number | null
  tags: string[]
  heading_id: string | null
  sort_order: number | null
  created_at: string
}

export interface Connection {
  id: string
  source_type: 'quote' | 'note'
  source_id: string
  target_type: 'quote' | 'note'
  target_id: string
  note: string | null
  created_at: string
  // joined
  target_book?: Book
  target_quote?: Quote
  target_note?: BookNote
}

// Schedule types
export interface ScheduleEntry {
  date: string // YYYY-MM-DD
  type: 'session' | 'priority'
  session?: Session
  priority?: PriorityItem
}

// Search result types
export type SearchResultType = 'quote' | 'note' | 'insight'

export interface SearchResult {
  type: SearchResultType
  id: string
  bookId: string
  bookTitle: string
  content: string
  tags?: string[]
  pageNumber?: number | null
  tab?: NoteTab
}
