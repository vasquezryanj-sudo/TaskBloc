'use client'

import { useState } from 'react'
import Modal from './Modal'
import type { Session, Book } from '@/types'

interface Props {
  session: Session & { book: Book }
  onClose: () => void
  onSuccess: () => void
}

export default function CompleteSessionModal({ session, onClose, onSuccess }: Props) {
  const [actualPage, setActualPage] = useState(String(session.pages_end))
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState('')

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault()
    setError('')
    setLoading(true)

    const res = await fetch(`/api/sessions/${session.id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'complete',
        actual_end_page: Number(actualPage),
      }),
    })

    if (!res.ok) {
      const data = await res.json()
      setError(data.error ?? 'Failed to complete session')
      setLoading(false)
      return
    }

    onSuccess()
    onClose()
  }

  return (
    <Modal title="Complete Session" onClose={onClose}>
      <form onSubmit={handleSubmit} className="space-y-4">
        <div className="bg-well-800/60 rounded-lg border border-well-800 px-4 py-3 text-sm">
          <p className="font-medium text-well-100">{session.book.title}</p>
          <p className="text-well-300 mt-0.5">
            Planned: pp. {session.pages_start}–{session.pages_end}
          </p>
        </div>

        <div>
          <label className="block text-sm font-medium text-well-200 mb-1">
            Actual end page
          </label>
          <input
            type="number"
            required
            min={session.pages_start}
            max={session.book.total_pages}
            value={actualPage}
            onChange={e => setActualPage(e.target.value)}
            className="w-full border border-well-800 bg-well-950 rounded-lg px-3 py-2 text-sm text-well-50 focus:outline-none focus:ring-2 focus:ring-ripple-600/20 focus:border-ripple-600/40 transition-all"
          />
          <p className="text-xs text-well-400 mt-1">
            Defaults to planned end page. Adjust if you read more or less.
          </p>
        </div>

        {error && <p className="text-sm text-rose-400">{error}</p>}

        <div className="flex gap-3 pt-1">
          <button
            type="button"
            onClick={onClose}
            className="flex-1 border border-well-800 text-well-300 px-4 py-2 rounded-lg text-sm hover:bg-well-800/60 transition-colors"
          >
            Cancel
          </button>
          <button
            type="submit"
            disabled={loading}
            className="flex-1 bg-ripple-600 hover:bg-ripple-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all disabled:opacity-50 shadow-[0_0_12px_rgba(8,116,224,0.2)]"
          >
            {loading ? 'Saving…' : 'Mark Complete'}
          </button>
        </div>
      </form>
    </Modal>
  )
}
