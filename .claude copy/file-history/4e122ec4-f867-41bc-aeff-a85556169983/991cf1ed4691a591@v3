'use client'

import { useState, useEffect, useCallback } from 'react'
import Link from 'next/link'
import { format, parseISO, addMonths } from 'date-fns'
import { supabase } from '@/lib/supabase'
import {
  DndContext,
  closestCenter,
  DragEndEvent,
  PointerSensor,
  useSensor,
  useSensors,
} from '@dnd-kit/core'
import {
  SortableContext,
  useSortable,
  verticalListSortingStrategy,
  arrayMove,
} from '@dnd-kit/sortable'
import { CSS } from '@dnd-kit/utilities'
import AddBookModal from '@/components/AddBookModal'
import AddArticleModal from '@/components/AddArticleModal'
import EditBookModal from '@/components/EditBookModal'
import CompleteSessionModal from '@/components/CompleteSessionModal'
import EditSessionModal from '@/components/EditSessionModal'
import SessionDetailModal from '@/components/SessionDetailModal'
import WeeklyCalendar from '@/components/WeeklyCalendar'
import GlobalSearch from '@/components/GlobalSearch'
import type { Book, Session, PriorityItem } from '@/types'

type SessionWithBook = Session & { book: Book }

// ── Sortable book row ──────────────────────────────────────────────────────────

function bookRole(sortOrder: number | null): { label: string; color: string } | null {
  if (sortOrder === 1) return { label: 'Primary', color: 'text-violet-300 bg-violet-900/40 border-violet-700/50' }
  if (sortOrder === 2) return { label: 'Secondary', color: 'text-amber-300 bg-amber-900/40 border-amber-700/50' }
  return null
}

function SortableBookRow({
  book,
  sessions,
  onComplete,
  onEdit,
}: {
  book: Book
  sessions: SessionWithBook[]
  onComplete: (book: Book) => void
  onEdit: (book: Book) => void
}) {
  const { attributes, listeners, setNodeRef, transform, transition, isDragging } = useSortable({
    id: book.id,
  })

  const style = {
    transform: CSS.Transform.toString(transform),
    transition,
    opacity: isDragging ? 0.45 : 1,
  }

  const bookSessions = sessions.filter(s => s.book_id === book.id)
  const lastSession = [...bookSessions].sort((a, b) =>
    b.scheduled_date.localeCompare(a.scheduled_date)
  )[0]
  const pct = book.total_pages > 0
    ? Math.round((book.current_page / book.total_pages) * 100)
    : 0

  const role = bookRole(book.sort_order)
  return (
    <div
      ref={setNodeRef}
      style={style}
      className="bg-well-900 rounded-xl px-4 py-3 flex items-center gap-3 transition-all duration-150 hover:bg-well-800 group"
    >
      {/* Drag handle */}
      <button
        {...attributes}
        {...listeners}
        className="text-well-700 hover:text-well-500 cursor-grab active:cursor-grabbing shrink-0 touch-none transition-colors"
        aria-label="Drag to reorder"
      >
        <svg width="12" height="16" viewBox="0 0 12 16" fill="currentColor">
          <circle cx="4" cy="3" r="1.5" />
          <circle cx="8" cy="3" r="1.5" />
          <circle cx="4" cy="8" r="1.5" />
          <circle cx="8" cy="8" r="1.5" />
          <circle cx="4" cy="13" r="1.5" />
          <circle cx="8" cy="13" r="1.5" />
        </svg>
      </button>

      {/* Role badge */}
      {role && (
        <span className={`shrink-0 text-[10px] font-semibold uppercase tracking-widest border px-2 py-0.5 rounded-full ${role.color}`}>
          {role.label}
        </span>
      )}

      {/* Book info */}
      <div className="flex-1 min-w-0">
        <p className="font-medium text-well-50 truncate">{book.title}</p>
        <div className="flex items-center gap-2.5 mt-1.5">
          <div className="w-32 bg-well-800 rounded-full h-1">
            <div
              className="bg-ripple-500 h-1 rounded-full transition-all shadow-[0_0_8px_rgba(99,102,241,0.5)]"
              style={{ width: `${pct}%` }}
            />
          </div>
          <p className="text-xs text-well-400">
            p.&nbsp;{book.current_page}/{book.total_pages}
            {lastSession && (
              <> · ~{format(parseISO(lastSession.scheduled_date), 'MMM d')}</>
            )}
          </p>
        </div>
      </div>

      <div className="flex items-center gap-2 shrink-0">
        <button
          onClick={() => onEdit(book)}
          className="text-xs text-well-500 hover:text-well-200 px-2.5 py-1 rounded-md bg-well-800 hover:bg-well-700 transition-all"
          title="Edit book"
        >
          Edit
        </button>
        <Link
          href={`/books/${book.id}`}
          className="text-xs text-well-500 hover:text-well-200 px-2.5 py-1 rounded-md bg-well-800 hover:bg-well-700 transition-all"
        >
          Notes
        </Link>
        <button
          onClick={() => onComplete(book)}
          className="w-6 h-6 flex items-center justify-center rounded-full text-well-600 hover:text-white hover:bg-ripple-600 transition-all"
          title="Mark as finished"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" className="w-3.5 h-3.5">
            <path fillRule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clipRule="evenodd" />
          </svg>
        </button>
      </div>
    </div>
  )
}

// ── Confirm complete book modal ────────────────────────────────────────────────

function ConfirmCompleteModal({
  book,
  onClose,
  onConfirm,
}: {
  book: Book
  onClose: () => void
  onConfirm: () => void
}) {
  const [loading, setLoading] = useState(false)

  async function handleConfirm() {
    setLoading(true)
    await onConfirm()
    setLoading(false)
  }

  return (
    <div
      className="fixed inset-0 bg-well-950/80 backdrop-blur-sm flex items-center justify-center z-50 p-4"
      onClick={e => { if (e.target === e.currentTarget) onClose() }}
    >
      <div className="bg-well-900 rounded-2xl shadow-[0_24px_80px_rgba(0,0,0,0.9)] w-full max-w-sm">
        <div className="px-6 py-6">
          <h2 className="font-semibold text-well-50 mb-2">Finish &ldquo;{book.title}&rdquo;?</h2>
          <p className="text-sm text-well-300 leading-relaxed">
            This will mark the book as completed, promote your Secondary book to Primary,
            and move the next queued book into the Secondary slot.
          </p>
          <div className="flex gap-3 mt-5">
            <button
              onClick={onClose}
              className="flex-1 bg-well-800 hover:bg-well-700 text-well-300 hover:text-well-100 px-4 py-2 rounded-full text-sm transition-all"
            >
              Cancel
            </button>
            <button
              onClick={handleConfirm}
              disabled={loading}
              className="flex-1 bg-ripple-600 hover:bg-ripple-500 text-white px-4 py-2 rounded-full text-sm font-medium transition-all disabled:opacity-50 shadow-[0_0_16px_rgba(79,70,229,0.3)]"
            >
              {loading ? 'Finishing…' : 'Yes, finish it'}
            </button>
          </div>
        </div>
      </div>
    </div>
  )
}

// ── Completed book card ────────────────────────────────────────────────────────

function CompletedBookCard({ book }: { book: Book }) {
  const [expanded, setExpanded] = useState(false)

  return (
    <div className="bg-well-900 rounded-xl overflow-hidden">
      <button
        onClick={() => setExpanded(e => !e)}
        className="w-full px-4 py-3 flex items-center gap-3 text-left hover:bg-well-800 transition-colors"
      >
        <span className="text-well-500 text-xs">
          {expanded ? '▾' : '▸'}
        </span>
        <p className="flex-1 font-medium text-well-300 truncate">{book.title}</p>
        {book.date_finished && (
          <span className="text-xs text-well-500 shrink-0">
            {format(parseISO(book.date_finished), 'MMM d, yyyy')}
          </span>
        )}
        <span className="text-xs text-ripple-400 font-medium shrink-0">✓ Finished</span>
      </button>

      {expanded && (
        <div className="px-4 pb-4 border-t border-well-800/60 pt-3 flex items-center justify-between gap-4">
          <div className="text-xs text-well-400 space-y-0.5">
            <p>{book.total_pages} pages</p>
            {book.date_finished && (
              <p>Finished {format(parseISO(book.date_finished), 'MMMM d, yyyy')}</p>
            )}
            <p>Added {format(parseISO(book.created_at), 'MMMM d, yyyy')}</p>
          </div>
          <Link
            href={`/books/${book.id}`}
            className="text-sm text-ripple-400 hover:text-ripple-300 font-medium shrink-0 transition-colors"
          >
            View Notes →
          </Link>
        </div>
      )}
    </div>
  )
}

// ── Article card ───────────────────────────────────────────────────────────────

function ArticleCard({ book, onDone }: { book: Book; onDone: (book: Book) => void }) {
  const [loading, setLoading] = useState(false)

  async function handleDone() {
    setLoading(true)
    await fetch(`/api/books/${book.id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: 'completed' }),
    })
    onDone(book)
  }

  return (
    <div className="bg-well-900 rounded-xl px-4 py-3 flex items-center gap-3 hover:bg-well-800 transition-colors">
      <div className="flex-1 min-w-0">
        <p className="font-medium text-well-50 truncate">{book.title}</p>
        <p className="text-xs text-amber-400/80 mt-0.5 font-medium">Article</p>
      </div>
      <div className="flex items-center gap-2 shrink-0">
        <Link
          href={`/books/${book.id}`}
          className="text-xs text-well-500 hover:text-well-200 px-2.5 py-1 rounded-md bg-well-800 hover:bg-well-700 transition-all"
        >
          Notes
        </Link>
        <button
          onClick={handleDone}
          disabled={loading}
          className="w-6 h-6 flex items-center justify-center rounded-full text-well-600 hover:text-white hover:bg-ripple-600 transition-all disabled:opacity-40"
          title="Mark done"
        >
          {loading ? (
            <span className="text-[10px]">…</span>
          ) : (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" className="w-3.5 h-3.5">
              <path fillRule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clipRule="evenodd" />
            </svg>
          )}
        </button>
      </div>
    </div>
  )
}

// ── Dashboard ──────────────────────────────────────────────────────────────────

export default function Dashboard() {
  const [books, setBooks] = useState<Book[]>([])
  const [sessions, setSessions] = useState<SessionWithBook[]>([])
  const [priorities, setPriorities] = useState<PriorityItem[]>([])
  const [loading, setLoading] = useState(true)
  const [weekOffset, setWeekOffset] = useState(0)

  const [showAddBook, setShowAddBook] = useState(false)
  const [showAddArticle, setShowAddArticle] = useState(false)
  const [showSearch, setShowSearch] = useState(false)
  const [selectedSession, setSelectedSession] = useState<SessionWithBook | null>(null)
  const [completeTarget, setCompleteTarget] = useState<SessionWithBook | null>(null)
  const [editTarget, setEditTarget] = useState<SessionWithBook | null>(null)
  const [selectedPriority, setSelectedPriority] = useState<PriorityItem | null>(null)
  const [completeBookTarget, setCompleteBookTarget] = useState<Book | null>(null)
  const [editBookTarget, setEditBookTarget] = useState<Book | null>(null)
  const [clearing, setClearing] = useState(false)
  const [confirmClear, setConfirmClear] = useState(false)

  const refresh = useCallback(async () => {
    const today = new Date().toISOString().split('T')[0]
    const future = format(addMonths(new Date(), 3), 'yyyy-MM-dd')
    const past = format(addMonths(new Date(), -1), 'yyyy-MM-dd')

    const [booksRes, sessionsRes, prioritiesRes] = await Promise.all([
      supabase
        .from('books')
        .select('*')
        .order('sort_order', { ascending: true })
        .order('created_at', { ascending: false }),
      supabase
        .from('sessions')
        .select('*, book:books(*)')
        .gte('scheduled_date', past)
        .lte('scheduled_date', future)
        .order('scheduled_date')
        .limit(300),
      supabase
        .from('priority_items')
        .select('*')
        .gte('scheduled_date', today)
        .eq('is_completed', false)
        .order('scheduled_date'),
    ])

    setBooks((booksRes.data as Book[]) ?? [])
    setSessions((sessionsRes.data as SessionWithBook[]) ?? [])
    setPriorities((prioritiesRes.data as PriorityItem[]) ?? [])
    setLoading(false)
  }, [])

  useEffect(() => { refresh() }, [refresh])

  // Cmd+K / Ctrl+K to open search
  useEffect(() => {
    function onKey(e: KeyboardEvent) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault()
        setShowSearch(s => !s)
      }
    }
    window.addEventListener('keydown', onKey)
    return () => window.removeEventListener('keydown', onKey)
  }, [])

  const sensors = useSensors(useSensor(PointerSensor, { activationConstraint: { distance: 8 } }))

  const activeBooks = books.filter(b => b.status === 'active' && b.type === 'book')
  const activeArticles = books.filter(b => b.status === 'active' && b.type === 'article')
  const completedBooks = books.filter(b => b.status === 'completed')

  async function handleDragEnd(event: DragEndEvent) {
    const { active, over } = event
    if (!over || active.id === over.id) return

    const oldIndex = activeBooks.findIndex(b => b.id === active.id)
    const newIndex = activeBooks.findIndex(b => b.id === over.id)
    if (oldIndex === -1 || newIndex === -1) return

    const reordered = arrayMove(activeBooks, oldIndex, newIndex)

    setBooks(prev => {
      const others = prev.filter(b => b.status !== 'active' || b.type !== 'book')
      return [...reordered.map((b, i) => ({ ...b, sort_order: i + 1 })), ...others]
    })

    await fetch('/api/books/reorder', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orderedIds: reordered.map(b => b.id) }),
    })

    await refresh()
  }

  async function handleCompleteBook(book: Book) {
    await fetch(`/api/books/${book.id}/complete`, { method: 'POST' })
    setCompleteBookTarget(null)
    await refresh()
  }

  async function handleCompletePriority(id: string) {
    await supabase.from('priority_items').update({ is_completed: true }).eq('id', id)
    setSelectedPriority(null)
    await refresh()
  }

  async function handleClearAll() {
    setClearing(true)
    await fetch('/api/dev/clear', { method: 'DELETE' })
    setConfirmClear(false)
    setClearing(false)
    await refresh()
  }

  async function handleDeletePriority(id: string) {
    await fetch(`/api/priority-items/${id}`, { method: 'DELETE' })
    setSelectedPriority(null)
    await refresh()
  }

  if (loading) {
    return (
      <div className="min-h-screen bg-well-950 flex items-center justify-center text-well-400 text-sm">
        Loading…
      </div>
    )
  }

  return (
    <div className="min-h-screen bg-well-950">
      {/* Header */}
      <header className="bg-well-950/95 border-b border-well-800/50 sticky top-0 z-10 backdrop-blur-xl">
        <div className="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
          <h1 className="text-lg font-semibold text-well-50 tracking-tight">MindWell</h1>
          <div className="flex items-center gap-2">
            <button
              onClick={() => setShowSearch(true)}
              className="text-sm text-well-400 hover:text-well-200 px-3 py-1.5 rounded-full transition-all flex items-center gap-2 bg-well-800 hover:bg-well-700"
              title="Search (⌘K)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" className="w-3.5 h-3.5">
                <path fillRule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clipRule="evenodd" />
              </svg>
              <span className="hidden sm:inline">Search</span>
              <kbd className="hidden sm:inline text-[10px] font-mono bg-well-700 text-well-500 px-1.5 py-0.5 rounded">⌘K</kbd>
            </button>
            <button
              onClick={() => setShowAddArticle(true)}
              className="text-sm text-well-300 hover:text-well-50 bg-well-800 hover:bg-well-700 px-4 py-1.5 rounded-full transition-all font-medium"
            >
              + Article
            </button>
            <button
              onClick={() => setShowAddBook(true)}
              className="text-sm text-white bg-ripple-600 hover:bg-ripple-500 px-4 py-1.5 rounded-full transition-all font-medium shadow-[0_0_16px_rgba(79,70,229,0.3)] hover:shadow-[0_0_20px_rgba(79,70,229,0.4)]"
            >
              + Book
            </button>
          </div>
        </div>
      </header>

      <main className="max-w-4xl mx-auto px-6 py-8 space-y-10">

        {/* ── Books ── */}
        <section>
          <div className="flex items-center justify-between mb-3">
            <h2 className="text-[11px] font-bold uppercase tracking-widest text-well-500">
              Books
            </h2>
            <p className="text-xs text-well-500">Drag to reorder · first = Primary, second = Secondary</p>
          </div>

          {activeBooks.length === 0 ? (
            <div className="text-center py-12 text-well-400 bg-well-900 rounded-xl">
              <p className="text-sm text-well-500 mb-3">No books yet</p>
              <button
                onClick={() => setShowAddBook(true)}
                className="text-sm text-ripple-400 hover:text-ripple-300 transition-colors font-medium"
              >
                Add your first book →
              </button>
            </div>
          ) : (
            <DndContext
              sensors={sensors}
              collisionDetection={closestCenter}
              onDragEnd={handleDragEnd}
            >
              <SortableContext items={activeBooks.map(b => b.id)} strategy={verticalListSortingStrategy}>
                <div className="space-y-2">
                  {activeBooks.map(book => (
                    <SortableBookRow
                      key={book.id}
                      book={book}
                      sessions={sessions}
                      onComplete={() => setCompleteBookTarget(book)}
                      onEdit={() => setEditBookTarget(book)}
                    />
                  ))}
                </div>
              </SortableContext>
            </DndContext>
          )}
        </section>

        {/* ── Articles ── */}
        {activeArticles.length > 0 && (
          <section>
            <h2 className="text-[11px] font-bold uppercase tracking-widest text-well-500 mb-3">
              Articles
            </h2>
            <div className="space-y-2">
              {activeArticles.map(article => (
                <ArticleCard key={article.id} book={article} onDone={refresh} />
              ))}
            </div>
          </section>
        )}

        {/* ── Schedule ── */}
        <section>
          <h2 className="text-[11px] font-bold uppercase tracking-widest text-well-500 mb-3">
            Schedule
          </h2>

          <WeeklyCalendar
            sessions={sessions}
            priorities={priorities}
            weekOffset={weekOffset}
            onChangeWeek={setWeekOffset}
            onSelectSession={setSelectedSession}
            onSelectPriority={setSelectedPriority}
            onSessionMoved={refresh}
          />
        </section>

        {/* ── Completed ── */}
        {completedBooks.length > 0 && (
          <section>
            <h2 className="text-[11px] font-bold uppercase tracking-widest text-well-500 mb-3">
              Completed
            </h2>
            <div className="space-y-2">
              {completedBooks
                .sort((a, b) => (b.date_finished ?? '').localeCompare(a.date_finished ?? ''))
                .map(book => (
                  <CompletedBookCard key={book.id} book={book} />
                ))}
            </div>
          </section>
        )}
      </main>

      {/* Modals */}
      {showAddBook && (
        <AddBookModal onClose={() => setShowAddBook(false)} onSuccess={refresh} />
      )}

      {showAddArticle && (
        <AddArticleModal onClose={() => setShowAddArticle(false)} onSuccess={refresh} />
      )}

      {selectedSession && !completeTarget && !editTarget && (
        <SessionDetailModal
          session={selectedSession}
          onClose={() => setSelectedSession(null)}
          onComplete={() => setCompleteTarget(selectedSession)}
          onEdit={() => setEditTarget(selectedSession)}
        />
      )}

      {completeTarget && (
        <CompleteSessionModal
          session={completeTarget}
          onClose={() => { setCompleteTarget(null); setSelectedSession(null) }}
          onSuccess={() => { setCompleteTarget(null); setSelectedSession(null); refresh() }}
        />
      )}

      {editTarget && (
        <EditSessionModal
          session={editTarget}
          onClose={() => { setEditTarget(null); setSelectedSession(null) }}
          onSuccess={() => { setEditTarget(null); setSelectedSession(null); refresh() }}
        />
      )}

      {/* Priority item detail */}
      {selectedPriority && (
        <div
          className="fixed inset-0 bg-well-950/80 backdrop-blur-sm flex items-center justify-center z-50 p-4"
          onClick={e => { if (e.target === e.currentTarget) setSelectedPriority(null) }}
        >
          <div className="bg-well-900 rounded-2xl shadow-[0_24px_80px_rgba(0,0,0,0.9)] w-full max-w-sm">
            <div className="flex items-center justify-between px-6 py-5 border-b border-well-800/60">
              <div className="flex items-center gap-2 min-w-0">
                <span className="text-[10px] font-semibold uppercase tracking-widest text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 rounded-full shrink-0">
                  Priority
                </span>
                <h2 className="font-semibold text-well-50 truncate">{selectedPriority.title}</h2>
              </div>
              <button
                onClick={() => setSelectedPriority(null)}
                className="w-7 h-7 flex items-center justify-center rounded-full text-well-500 hover:text-well-200 hover:bg-well-800 text-lg leading-none ml-2 transition-all"
              >
                ×
              </button>
            </div>
            <div className="px-6 py-5 space-y-4">
              {selectedPriority.description && (
                <p className="text-sm text-well-300 leading-relaxed">{selectedPriority.description}</p>
              )}
              <p className="text-sm text-well-500">
                {selectedPriority.sessions_needed} session{selectedPriority.sessions_needed !== 1 ? 's' : ''} displaced
              </p>
              <div className="grid grid-cols-2 gap-3 pt-1">
                <button
                  onClick={() => handleDeletePriority(selectedPriority.id)}
                  className="bg-well-800 hover:bg-rose-900/60 text-well-300 hover:text-rose-300 px-4 py-2 rounded-full text-sm transition-all"
                >
                  Delete
                </button>
                <button
                  onClick={() => handleCompletePriority(selectedPriority.id)}
                  className="bg-amber-500 hover:bg-amber-400 text-black px-4 py-2 rounded-full text-sm font-semibold transition-all"
                >
                  ✓ Done
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {completeBookTarget && (
        <ConfirmCompleteModal
          book={completeBookTarget}
          onClose={() => setCompleteBookTarget(null)}
          onConfirm={() => handleCompleteBook(completeBookTarget)}
        />
      )}

      {editBookTarget && (
        <EditBookModal
          book={editBookTarget}
          onClose={() => setEditBookTarget(null)}
          onSuccess={() => { setEditBookTarget(null); refresh() }}
        />
      )}

      {/* Global Search */}
      {showSearch && <GlobalSearch onClose={() => setShowSearch(false)} />}

      {/* Dev footer */}
      <footer className="max-w-4xl mx-auto px-6 py-6 flex justify-end">
        {confirmClear ? (
          <div className="flex items-center gap-3">
            <span className="text-xs text-well-500">Wipe all books, sessions & articles?</span>
            <button
              onClick={() => setConfirmClear(false)}
              className="text-xs text-well-500 hover:text-well-200 transition-colors"
            >
              Cancel
            </button>
            <button
              onClick={handleClearAll}
              disabled={clearing}
              className="text-xs text-white bg-rose-600 hover:bg-rose-500 px-3 py-1.5 rounded-full transition-colors disabled:opacity-50"
            >
              {clearing ? 'Clearing…' : 'Yes, clear everything'}
            </button>
          </div>
        ) : (
          <button
            onClick={() => setConfirmClear(true)}
            className="text-xs text-well-700 hover:text-rose-400 transition-colors"
          >
            Clear all data
          </button>
        )}
      </footer>
    </div>
  )
}
