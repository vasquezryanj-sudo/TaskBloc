'use client'

import { useState } from 'react'
import Modal from './Modal'
import type { Book } from '@/types'

interface Props {
  book: Book
  onClose: () => void
  onSuccess: () => void
  onDelete: () => void
}

export default function EditBookModal({ book, onClose, onSuccess, onDelete }: Props) {
  const [form, setForm] = useState({
    title: book.title,
    total_pages: String(book.total_pages),
    current_page: String(book.current_page),
  })
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState('')
  const [confirmDelete, setConfirmDelete] = useState(false)
  const [deleting, setDeleting] = useState(false)

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault()
    setError('')
    setLoading(true)

    const res = await fetch(`/api/books/${book.id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        title: form.title.trim(),
        total_pages: Number(form.total_pages),
        current_page: Number(form.current_page),
      }),
    })

    if (!res.ok) {
      const data = await res.json()
      setError(data.error ?? 'Failed to update book')
      setLoading(false)
      return
    }

    onSuccess()
    onClose()
  }

  async function handleDelete() {
    setDeleting(true)
    await fetch(`/api/books/${book.id}`, { method: 'DELETE' })
    onDelete()
    onClose()
  }

  return (
    <Modal title="Edit Book" onClose={onClose}>
      <form onSubmit={handleSubmit} className="space-y-4">
        <div>
          <label className="block text-sm font-medium text-well-200 mb-1">Title</label>
          <input
            type="text"
            required
            autoFocus
            value={form.title}
            onChange={e => setForm(f => ({ ...f, title: e.target.value }))}
            className="w-full bg-well-800 border-0 rounded-lg px-3 py-2.5 text-sm text-well-50 focus:outline-none focus:ring-2 focus:ring-cream-200/20 transition-all"
          />
        </div>

        <div className="grid grid-cols-2 gap-3">
          <div>
            <label className="block text-sm font-medium text-well-200 mb-1">Total pages</label>
            <input
              type="number"
              required
              min={1}
              value={form.total_pages}
              onChange={e => setForm(f => ({ ...f, total_pages: e.target.value }))}
              className="w-full bg-well-800 border-0 rounded-lg px-3 py-2.5 text-sm text-well-50 focus:outline-none focus:ring-2 focus:ring-cream-200/20 transition-all"
            />
          </div>
          <div>
            <label className="block text-sm font-medium text-well-200 mb-1">Current page</label>
            <input
              type="number"
              min={0}
              max={Number(form.total_pages) || undefined}
              value={form.current_page}
              onChange={e => setForm(f => ({ ...f, current_page: e.target.value }))}
              className="w-full bg-well-800 border-0 rounded-lg px-3 py-2.5 text-sm text-well-50 focus:outline-none focus:ring-2 focus:ring-cream-200/20 transition-all"
            />
          </div>
        </div>

        {error && <p className="text-sm text-rose-400">{error}</p>}

        <div className="flex gap-3 pt-1">
          <button
            type="button"
            onClick={onClose}
            className="flex-1 bg-well-800 hover:bg-well-700 text-well-300 hover:text-well-100 px-4 py-2 rounded-full text-sm transition-all"
          >
            Cancel
          </button>
          <button
            type="submit"
            disabled={loading}
            className="flex-1 bg-cream-200 hover:bg-cream-100 text-well-950 px-4 py-2 rounded-full text-sm font-medium transition-all disabled:opacity-50"
          >
            {loading ? 'Saving…' : 'Save'}
          </button>
        </div>

        <div className="border-t border-well-800 pt-4">
          {confirmDelete ? (
            <div className="flex items-center justify-between gap-3">
              <span className="text-xs text-well-400">Delete &ldquo;{book.title}&rdquo;?</span>
              <div className="flex items-center gap-2">
                <button
                  type="button"
                  onClick={() => setConfirmDelete(false)}
                  className="text-xs text-well-500 hover:text-well-200 transition-colors"
                >
                  Cancel
                </button>
                <button
                  type="button"
                  onClick={handleDelete}
                  disabled={deleting}
                  className="text-xs text-white bg-rose-600 hover:bg-rose-500 px-3 py-1.5 rounded-full transition-colors disabled:opacity-50"
                >
                  {deleting ? 'Deleting…' : 'Delete'}
                </button>
              </div>
            </div>
          ) : (
            <button
              type="button"
              onClick={() => setConfirmDelete(true)}
              className="text-xs text-well-600 hover:text-rose-400 transition-colors"
            >
              Delete book
            </button>
          )}
        </div>
      </form>
    </Modal>
  )
}
