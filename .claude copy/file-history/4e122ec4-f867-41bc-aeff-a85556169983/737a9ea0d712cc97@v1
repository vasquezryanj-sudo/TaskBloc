@import "tailwindcss";

@theme inline {
  --font-sans: var(--font-geist);
  --font-serif: var(--font-lora);
}

@theme {
  /* Parchment — warm aged paper */
  --color-parchment-50:  #fdf9f4;
  --color-parchment-100: #f8f0e3;
  --color-parchment-200: #f0e4cd;
  --color-parchment-300: #d8c9b0;
  --color-parchment-400: #c0a882;
  --color-parchment-500: #a08060;
  --color-parchment-600: #8b5e3c;
  --color-parchment-700: #6b4226;
  --color-parchment-800: #4a2c14;
  --color-parchment-900: #2c1a0e;

  /* Forest — deep library green */
  --color-forest-50:  #edf4e8;
  --color-forest-100: #d5e9c4;
  --color-forest-200: #aacf88;
  --color-forest-500: #4e8528;
  --color-forest-600: #3d6b1e;
  --color-forest-700: #2d5016;
  --color-forest-800: #1e3a0f;
  --color-forest-900: #122208;
}

body {
  font-family: var(--font-sans), system-ui, sans-serif;
}
