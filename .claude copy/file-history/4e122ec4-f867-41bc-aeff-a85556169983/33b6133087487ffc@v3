'use client'

import { useState } from 'react'
import Modal from './Modal'
import { supabase } from '@/lib/supabase'
import type { Session, Book } from '@/types'

interface Props {
  session: Session & { book: Book }
  onClose: () => void
  onSuccess: () => void
}

export default function EditSessionModal({ session, onClose, onSuccess }: Props) {
  const [date, setDate] = useState(session.scheduled_date)
  const [pagesEnd, setPagesEnd] = useState(String(session.pages_end))
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState('')

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault()
    setError('')
    setLoading(true)

    const { error: err } = await supabase
      .from('sessions')
      .update({ scheduled_date: date, pages_end: Number(pagesEnd) })
      .eq('id', session.id)

    if (err) {
      setError(err.message)
      setLoading(false)
      return
    }

    onSuccess()
    onClose()
  }

  return (
    <Modal title="Edit Session" onClose={onClose}>
      <form onSubmit={handleSubmit} className="space-y-4">
        <div className="bg-well-800/60 rounded-lg border border-well-800 px-4 py-3 text-sm">
          <p className="font-medium text-well-100">{session.book.title}</p>
          <p className="text-well-300 mt-0.5">pp. {session.pages_start}–{session.pages_end}</p>
        </div>

        <div>
          <label className="block text-sm font-medium text-well-200 mb-1">Scheduled date</label>
          <input
            type="date"
            required
            value={date}
            onChange={e => setDate(e.target.value)}
            className="w-full bg-well-800 border-0 rounded-lg px-3 py-2.5 text-sm text-well-50 focus:outline-none focus:ring-2 focus:ring-ripple-600/40 transition-all"
          />
        </div>

        <div>
          <label className="block text-sm font-medium text-well-200 mb-1">End page target</label>
          <input
            type="number"
            required
            min={session.pages_start}
            max={session.book.total_pages}
            value={pagesEnd}
            onChange={e => setPagesEnd(e.target.value)}
            className="w-full bg-well-800 border-0 rounded-lg px-3 py-2.5 text-sm text-well-50 focus:outline-none focus:ring-2 focus:ring-ripple-600/40 transition-all"
          />
        </div>

        {error && <p className="text-sm text-rose-400">{error}</p>}

        <div className="flex gap-3 pt-1">
          <button
            type="button"
            onClick={onClose}
            className="flex-1 bg-well-800 hover:bg-well-700 text-well-300 hover:text-well-100 px-4 py-2 rounded-full text-sm transition-all"
          >
            Cancel
          </button>
          <button
            type="submit"
            disabled={loading}
            className="flex-1 bg-ripple-600 hover:bg-ripple-500 text-white px-4 py-2 rounded-full text-sm font-medium transition-all disabled:opacity-50 shadow-[0_0_16px_rgba(79,70,229,0.25)]"
          >
            {loading ? 'Saving…' : 'Save Changes'}
          </button>
        </div>
      </form>
    </Modal>
  )
}
