'use client'

import type { Session, Book } from '@/types'

interface Props {
  session: Session & { book: Book }
  onComplete: () => void
  onEdit: () => void
}

export default function SessionCard({ session, onComplete, onEdit }: Props) {
  const { book } = session
  const pageCount = session.pages_end - session.pages_start + 1
  const pctBefore = book.total_pages > 0
    ? Math.round((session.pages_start - 1) / book.total_pages * 100)
    : 0
  const pctAfter = book.total_pages > 0
    ? Math.round(session.pages_end / book.total_pages * 100)
    : 0

  return (
    <div className="bg-white rounded-lg border border-slate-200 flex overflow-hidden">
      {/* Blue left accent */}
      <div className="w-1 shrink-0 bg-blue-500" />
      <div className="flex-1 px-4 py-3 flex items-center justify-between gap-4">
        <div className="min-w-0">
          <p className="font-medium text-slate-900 truncate">{book.title}</p>
          <p className="text-sm text-slate-500 mt-0.5">
            pp. {session.pages_start}–{session.pages_end}
            <span className="mx-1.5 text-slate-300">·</span>
            {pageCount} pages
            <span className="mx-1.5 text-slate-300">·</span>
            {pctBefore}% → {pctAfter}%
          </p>
        </div>
        <div className="flex items-center gap-2 shrink-0">
          <button
            onClick={onEdit}
            className="text-sm text-slate-400 hover:text-slate-700 px-2 py-1 rounded hover:bg-slate-100 transition-colors"
          >
            Edit
          </button>
          <button
            onClick={onComplete}
            className="text-sm bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded-md transition-colors font-medium"
          >
            ✓ Done
          </button>
        </div>
      </div>
    </div>
  )
}
