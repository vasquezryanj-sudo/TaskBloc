import { NextRequest } from 'next/server'
import { supabase } from '@/lib/supabase'

export async function GET() {
  const { data, error } = await supabase
    .from('priority_items')
    .select('*')
    .order('scheduled_date', { ascending: true })
  if (error) return Response.json({ error: error.message }, { status: 500 })
  return Response.json(data)
}

export async function POST(req: NextRequest) {
  const body = await req.json()
  const { title, description = null, sessions_needed = 1, scheduled_date } = body

  if (!title || !scheduled_date) {
    return Response.json({ error: 'title and scheduled_date are required' }, { status: 400 })
  }

  const { data, error } = await supabase
    .from('priority_items')
    .insert({ title, description, sessions_needed, scheduled_date, is_completed: false })
    .select()
    .single()
  if (error) return Response.json({ error: error.message }, { status: 500 })
  return Response.json(data, { status: 201 })
}
