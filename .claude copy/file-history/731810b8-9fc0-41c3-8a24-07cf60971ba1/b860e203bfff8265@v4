'use client'

import { startOfWeek, addDays, addWeeks, format, isToday, isBefore, startOfDay } from 'date-fns'
import type { Book, Session, PriorityItem } from '@/types'

type SessionWithBook = Session & { book: Book }

interface Props {
  sessions: SessionWithBook[]
  priorities: PriorityItem[]
  weekOffset: number
  onChangeWeek: (offset: number) => void
  onSelectSession: (session: SessionWithBook) => void
  onSelectPriority: (item: PriorityItem) => void
}

const DAYS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']

function sessionStyle(session: SessionWithBook): {
  border: string
  bg: string
  hoverBg: string
  titleColor: string
  titleHover: string
  metaColor: string
} {
  const order = session.book.sort_order ?? 99
  if (order === 1) {
    // Primary: violet
    return {
      border: 'border-violet-400',
      bg: 'bg-violet-50/60',
      hoverBg: 'hover:bg-violet-50',
      titleColor: 'text-violet-900',
      titleHover: 'group-hover:text-violet-700',
      metaColor: 'text-violet-400',
    }
  }
  if (order === 2) {
    // Secondary: amber/yellow
    return {
      border: 'border-amber-400',
      bg: 'bg-amber-50/60',
      hoverBg: 'hover:bg-amber-50',
      titleColor: 'text-amber-900',
      titleHover: 'group-hover:text-amber-700',
      metaColor: 'text-amber-400',
    }
  }
  // Default: blue
  return {
    border: 'border-blue-400',
    bg: 'bg-white',
    hoverBg: 'hover:bg-blue-50',
    titleColor: 'text-slate-800',
    titleHover: 'group-hover:text-blue-700',
    metaColor: 'text-slate-400',
  }
}

export default function WeeklyCalendar({
  sessions,
  priorities,
  weekOffset,
  onChangeWeek,
  onSelectSession,
  onSelectPriority,
}: Props) {
  const todayStart = startOfDay(new Date())
  const weekStart = addWeeks(startOfWeek(new Date(), { weekStartsOn: 1 }), weekOffset)
  const days = Array.from({ length: 7 }, (_, i) => addDays(weekStart, i))
  const weekLabel = `${format(days[0], 'MMM d')} – ${format(days[6], 'MMM d, yyyy')}`

  return (
    <div>
      {/* Week navigation */}
      <div className="flex items-center justify-between mb-4">
        <button
          onClick={() => onChangeWeek(weekOffset - 1)}
          className="text-sm text-slate-500 hover:text-slate-900 px-3 py-1.5 rounded-lg hover:bg-slate-100 transition-colors"
        >
          ← Prev
        </button>
        <span className="text-sm font-medium text-slate-600">{weekLabel}</span>
        <button
          onClick={() => onChangeWeek(weekOffset + 1)}
          className="text-sm text-slate-500 hover:text-slate-900 px-3 py-1.5 rounded-lg hover:bg-slate-100 transition-colors"
        >
          Next →
        </button>
      </div>

      {/* Calendar grid */}
      <div className="overflow-x-auto">
        <div className="grid grid-cols-7 min-w-[560px] rounded-xl border border-slate-200 overflow-hidden bg-white">
          {days.map((day, i) => {
            const iso = format(day, 'yyyy-MM-dd')
            const isCurrentDay = isToday(day)
            const isPast = isBefore(day, todayStart)
            const daySessions = sessions.filter(s => s.scheduled_date === iso)
            const dayItems = priorities.filter(p => p.scheduled_date === iso)

            // Separate completed vs upcoming
            const completedSessions = daySessions.filter(s => s.is_completed)
            const upcomingSessions = daySessions.filter(s => !s.is_completed)

            return (
              <div
                key={iso}
                className={`flex flex-col ${i < 6 ? 'border-r border-slate-100' : ''} ${
                  isCurrentDay ? 'bg-blue-50/50' : ''
                }`}
              >
                {/* Day header */}
                <div className={`px-2.5 pt-3 pb-2 border-b border-slate-100 ${
                  isCurrentDay ? 'bg-blue-100/40' : ''
                }`}>
                  <p className={`text-[11px] font-bold tracking-wider uppercase ${
                    isCurrentDay ? 'text-blue-500' : isPast ? 'text-slate-300' : 'text-slate-400'
                  }`}>
                    {DAYS[i]}
                  </p>
                  <p className={`text-2xl font-semibold leading-tight mt-0.5 ${
                    isCurrentDay
                      ? 'text-blue-600'
                      : isPast
                      ? 'text-slate-300'
                      : 'text-slate-700'
                  }`}>
                    {format(day, 'd')}
                  </p>
                </div>

                {/* Sessions + priority items */}
                <div className="p-1.5 space-y-1.5 min-h-28 flex-1">
                  {/* Completed sessions: dimmed with strikethrough */}
                  {completedSessions.map(session => (
                    <button
                      key={session.id}
                      onClick={() => onSelectSession(session)}
                      className="w-full text-left rounded-md border-l-[3px] border-slate-200 bg-slate-50 px-2 py-1.5 text-xs shadow-sm hover:shadow transition-all group opacity-60"
                    >
                      <p className="font-semibold truncate leading-tight text-slate-400 line-through">
                        {session.book.title}
                      </p>
                      <p className="mt-0.5 text-slate-300 flex items-center gap-1">
                        <span>✓</span>
                        <span>pp.&nbsp;{session.pages_start}–{session.actual_end_page ?? session.pages_end}</span>
                      </p>
                    </button>
                  ))}

                  {/* Upcoming sessions */}
                  {upcomingSessions.map(session => {
                    const style = sessionStyle(session)
                    return (
                      <button
                        key={session.id}
                        onClick={() => onSelectSession(session)}
                        className={`w-full text-left rounded-md border-l-[3px] px-2 py-1.5 text-xs shadow-sm hover:shadow transition-all group ${style.border} ${style.bg} ${style.hoverBg}`}
                      >
                        <p className={`font-semibold truncate leading-tight transition-colors ${style.titleColor} ${style.titleHover}`}>
                          {session.book.title}
                        </p>
                        <p className={`mt-0.5 ${style.metaColor}`}>
                          pp.&nbsp;{session.pages_start}–{session.pages_end}
                        </p>
                      </button>
                    )
                  })}

                  {dayItems.map(item => (
                    <button
                      key={item.id}
                      onClick={() => onSelectPriority(item)}
                      className="w-full text-left rounded-md border-l-[3px] border-orange-400 bg-white hover:bg-orange-50 px-2 py-1.5 text-xs shadow-sm hover:shadow transition-all group"
                    >
                      <p className="font-semibold text-slate-800 truncate group-hover:text-orange-700 transition-colors leading-tight">
                        {item.title}
                      </p>
                      <p className="text-orange-500 mt-0.5">Priority item</p>
                    </button>
                  ))}
                </div>
              </div>
            )
          })}
        </div>
      </div>
    </div>
  )
}
